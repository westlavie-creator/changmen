# changmen 团队 CODEOWNERS 模板
#
# 用法：
#   1. 复制到仓库根：  .github/CODEOWNERS
#   2. 将 @CHANGMEN_CLIENT_TEAM / @CHANGMEN_SERVER_TEAM 换成 GitHub 用户名或 org/team
#
# 路径相对于仓库根（gamebet/）

# --- 客户端团队 ---
/changmen/client/web/                    @CHANGMEN_CLIENT_TEAM
/changmen/client/chrome-extension/       @CHANGMEN_CLIENT_TEAM
/changmen/client/platform-adapter/       @CHANGMEN_CLIENT_TEAM

# --- 服务端团队 ---
/changmen/server/backend/                @CHANGMEN_SERVER_TEAM
/changmen/server/matcher/                @CHANGMEN_SERVER_TEAM
/changmen/server/db/                     @CHANGMEN_SERVER_TEAM
/changmen/server/platform-node/          @CHANGMEN_SERVER_TEAM
/changmen/server/match-engine/           @CHANGMEN_SERVER_TEAM
/changmen/server/team-resolver/         @CHANGMEN_SERVER_TEAM

# --- 共同维护（双方都需 review）---
/changmen/packages/shared/               @CHANGMEN_CLIENT_TEAM @CHANGMEN_SERVER_TEAM
/changmen/packages/api-contract/         @CHANGMEN_CLIENT_TEAM @CHANGMEN_SERVER_TEAM
/changmen/docs/TEAM_BOUNDARIES.md       @CHANGMEN_CLIENT_TEAM @CHANGMEN_SERVER_TEAM
/changmen/scripts/check-team-boundaries.mjs @CHANGMEN_CLIENT_TEAM @CHANGMEN_SERVER_TEAM
