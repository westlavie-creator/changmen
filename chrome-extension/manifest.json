{
  "manifest_version": 3,
  "name": "じらいや",
  "version": "1.2.3",
  "key": "",
  "action": {
    "default_popup": "popup.html",
    "default_title": "じらいや",
    "default_icon": {
      "16": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.png",
        "assets/*.jpg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "https://*/*",
      "http://*/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "vendor/socket.io.bundle.js",
        "content.js"
      ],
      "css": [
        "assets/content.css"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "*://*.dexsport.io/*",
        "*://*.dexsport.app/*"
      ],
      "js": [
        "dex-intercept.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "activeTab"
  ]
}
