{
  "manifest_version": 3,
  "name": "OB Data Collector",
  "version": "1.0.0",
  "description": "Local-only passive collector for OB match, market, odds, and realtime update analysis.",
  "permissions": [
    "storage",
    "activeTab",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "OB Collector",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "core.js",
        "hook.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
