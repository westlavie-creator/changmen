{
  "name": "@changmen/backend",
  "version": "1.0.2",
  "private": true,
  "description": "Server: esport-api, HTTP proxy, static hosting for clients",
  "repository": {
    "type": "git",
    "url": "https://github.com/westlavie-creator/gamebet.git"
  },
  "type": "module",
  "scripts": {
    "patch:ui": "node ../web/patch-ui-bundle.js",
    "preweb": "node scripts/preweb.js",
    "web": "node scripts/start-db.mjs",
    "web:supabase": "node scripts/start-supabase.mjs",
    "web:rds": "node scripts/start-rds.mjs",
    "web:dual": "node scripts/start-dual.mjs",
    "web:restart": "node restart.js",
    "web:restart:bg": "node restart.js --background",
    "ob:login": "node ../../packages/platform-adapter/ob/backend/scripts/fetch_ob_login.js",
    "ob:view": "node ../../packages/platform-adapter/ob/backend/scripts/fetch_ob_view.js",
    "ob:live": "node ../../packages/platform-adapter/ob/backend/scripts/fetch_ob_live.js",
    "ob:mqtt": "node ../../packages/platform-adapter/ob/backend/scripts/fetch_ob_mqtt.js",
    "ob:hybrid": "node ../../packages/platform-adapter/ob/backend/scripts/ob_collect_hybrid.js",
    "ob:probe-index": "node ../../packages/platform-adapter/ob/backend/scripts/probe_game_index.js",
    "ob:collect-game-ids": "node ../../packages/platform-adapter/ob/backend/scripts/collect_game_ids.js",
    "ob:collect-odd-types": "node ../../packages/platform-adapter/ob/backend/scripts/collect_odd_type_ids.js",
    "ray:match": "node ../../packages/platform-adapter/ray/backend/scripts/fetch_ray_match.js",
    "ray:odds": "node ../../packages/platform-adapter/ray/backend/scripts/fetch_ray_odds.js",
    "ray:ws": "node ../../packages/platform-adapter/ray/backend/scripts/fetch_ray_ws.js",
    "pb:odds": "node ../../packages/platform-adapter/pb/backend/scripts/fetch_pb_odds.js",
    "pb:match": "node ../../packages/platform-adapter/pb/backend/scripts/fetch_pb_odds.js match",
    "pb:balance": "node ../../packages/platform-adapter/pb/backend/scripts/fetch_pb_odds.js balance",
    "tf:events": "node ../../packages/platform-adapter/tf/backend/scripts/fetch_tf_events.js",
    "ia:events": "node ../../packages/platform-adapter/ia/backend/scripts/fetch_ia_events.js",
    "imt:events": "node ../../packages/platform-adapter/imt/backend/scripts/fetch_imt_events.js",
    "stake:sports": "node ../../packages/platform-adapter/stake/backend/scripts/fetch_stake_sports.js",
    "saba:parse": "node ../../packages/platform-adapter/saba/backend/scripts/fetch_saba_page.js",
    "hg:balance": "node ../../packages/platform-adapter/hg/backend/scripts/fetch_hg_balance.js",
    "account:cli": "node scripts/account_cli.js",
    "account:tags": "node scripts/account_cli.js tags",
    "account:list": "node scripts/account_cli.js list",
    "account:refresh": "node scripts/account_cli.js refresh-balance",
    "account:create": "node scripts/account_cli.js create",
    "account:import-platform": "node scripts/account_cli.js import-platform",
    "account:set-a8": "node scripts/account_cli.js set-a8",
    "user:create": "node scripts/create-user.js",
    "user:sync": "node scripts/sync-user-data.js",
    "db:apply": "node scripts/apply-rds-schema.mjs",
    "db:apply:cron": "node scripts/apply-rds-schema.mjs --with-cron",
    "db:prune": "node scripts/prune-stale.mjs",
    "db:import-supabase": "node scripts/import-from-supabase.mjs",
    "check:collect": "node scripts/check-collect-platforms.js",
    "check:collect:probe": "node scripts/check-collect-platforms.js --probe",
    "test": "npm run test --prefix ../matcher && vitest run core/shared && npm run test:adapter",
    "test:watch": "vitest",
    "test:adapter": "node scripts/test-packaged-adapter-layout.js",
    "test:packaged-adapter": "node scripts/test-packaged-adapter-layout.js",
    "sync:a8-assets": "node scripts/sync-a8-esport2-assets.mjs",
    "compile:router": "tsc -p tsconfig.router.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@changmen/db": "*",
    "@supabase/supabase-js": "^2.106.2",
    "dotenv": "^17.4.2",
    "mqtt": "^5.14.0",
    "pg": "^8.21.0",
    "socket.io-client": "^4.8.3",
    "socketcluster-client": "^20.0.1",
    "socks-proxy-agent": "^8.0.5",
    "ws": "^8.21.0"
  }
}
