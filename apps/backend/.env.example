# ── 服务端（npm run web / 服务器部署）────────────────────────
# 认证模式：supabase（默认，与现网一致）| jwt（RDS users 表 + 自签 JWT）
# AUTH_MODE=supabase
# AUTH_MODE=jwt
# JWT_SECRET=至少16字符随机串
# JWT_ACCESS_TTL=7d
# JWT_REFRESH_TTL=30d

# 迁 RDS：内网 + 外网可同时配置，启动时 auto 探测（内网优先）
# DATABASE_URL_PUBLIC=postgresql://gamebet_app:PASSWORD@pgm-xxxxxho.pg.rds.aliyuncs.com:5432/gamebet
# DATABASE_URL_INTERNAL=postgresql://gamebet_app:PASSWORD@pgm-xxxxx.pg.rds.aliyuncs.com:5432/gamebet
# DATABASE_RDS_TARGET=auto   # auto | internal | public
# 仅配一条时仍可用 DATABASE_URL=...
# 外网 endpoint 若不支持 SSL 则勿设 DATABASE_SSL；需要 SSL 时：DATABASE_SSL=1

# 数据层脚本选择（npm run web / matcher 读取；也可用 web:supabase / web:rds / web:dual）：
#   supabase — 读写 Supabase（默认）
#   rds      — 读+写 RDS（需 DATABASE_URL 或 PUBLIC/INTERNAL）
#   dual     — 读 RDS，写 Supabase + RDS（迁库过渡期双写）
# GAMEBET_DB_SCRIPT=supabase
# GAMEBET_DB_SCRIPT=rds
# GAMEBET_DB_SCRIPT=dual
# 切换：cd changmen && npm run db:mode -- dual --restart
# 旧版 RDS_DUAL_WRITE=1 仍会被视为 dual，建议改用 GAMEBET_DB_SCRIPT=dual

# M4 导入 auth.users 密码 hash（Supabase → Database → Connection string URI，非 API URL）
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_anon_public_key
SUPABASE_SERVICE_KEY=your_service_role_key

# 管理系统可见用户（逗号分隔用户名，默认 admin）
# ADMIN_USERNAMES=admin,ops

# ── Electron 远程壳（可选；打包或便携版 exe 同级 .env）────────
# 开发默认 http://127.0.0.1:5174/，无需设置
# GAMEBET_REMOTE_APP_URL=https://your-domain.com/
