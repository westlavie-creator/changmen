# 复制为 .env 并填写真实值；通常不建此文件，自动读 ../backend/.env
# 完整变量表见 ../backend/.env.example；Matcher 读取逻辑见 lib/config.js

# supabase 模式：仅需 SUPABASE_*；rds/dual 模式：需 DATABASE_URL 或 DATABASE_URL_PUBLIC/INTERNAL
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# GAMEBET_DB_SCRIPT=supabase | rds | dual（与 backend 一致，改后重启 matcher:loop）
# MATCHER_INTERVAL_MS=30000
# MATCHER_PRUNE_INTERVAL_MS=3600000
# MATCHER_UI_PORT=4567
# PIPEI_PORT=4567（兼容旧名）
# MATCHER_SKIP_AUTH=1（须同时 NODE_ENV=development 或 test；生产须管理员 JWT）
