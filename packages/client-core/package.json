    "./bridge/oddsAccess": "./src/bridge/oddsAccess.ts",
    "./chrome-plugin/bridge": "./src/chrome-plugin/bridge.ts",
    "./models/betOption": "./src/models/betOption.ts",
    "./models/betResult": "./src/models/betResult.ts",
    "./models/loseOrder": "./src/models/loseOrder.ts",
    "./models/match": "./src/models/match.ts",
    "./models/platformAccount": "./src/models/platformAccount.ts",
    "./shared/a8Axios": "./src/shared/a8Axios.ts",
    "./shared/bracketForm": "./src/shared/bracketForm.ts",
    "./shared/format": "./src/shared/format.ts",
    "./shared/hkRelayOrigin": "./src/shared/hkRelayOrigin.ts",
    "./shared/http": "./src/shared/http.ts",
