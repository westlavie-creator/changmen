{
  "name": "gamebet-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "node scripts/extract-a8-css.mjs",
    "dev": "vite",
    "electron": "electron .",
    "electron:dev": "set GAMEBET_ELECTRON_DEV_URL=http://127.0.0.1:5174&& electron .",
    "electron:build": "node scripts/extract-a8-css.mjs && vue-tsc -b && vite build --base=./",
    "prebuild": "node scripts/extract-a8-css.mjs",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --base /app/",
    "test:v4": "node scripts/test-v4-credit-plate.mjs",
    "test:ob-getmatchs": "node scripts/test-ob-getmatchs-shape.mjs",
    "test:ob-provider": "node scripts/test-ob-provider-contract.mjs",
    "test:ob-live": "node scripts/test-ob-live-smoke.mjs",
    "test:ob": "npm run test:ob-getmatchs && npm run test:ob-provider",
    "test:ob:all": "npm run test:ob && npm run test:ob-live",
    "audit:a8": "node scripts/audit-a8-parity.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@vueuse/core": "^13.2.0",
    "axios": "^1.8.4",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.0",
    "goeasy": "^2.14.9",
    "mqtt": "^5.14.1",
    "pinia": "^3.0.2",
    "socket.io-client": "^4.8.1",
    "socketcluster-client": "^19.2.0",
    "tronweb": "^6.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^42.3.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.8"
  }
}
