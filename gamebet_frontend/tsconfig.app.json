{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@platform/*": ["../platform_adapter/*"],
      "mqtt": ["./node_modules/mqtt"],
      "socket.io-client": ["./node_modules/socket.io-client"],
      "socketcluster-client": ["./node_modules/socketcluster-client"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "../platform_adapter/**/index.ts",
    "../platform_adapter/**/frontend/**/*.ts",
    "../platform_adapter/shared/**/*.ts",
    "../platform_adapter/registry/**/*.ts",
    "../platform_adapter/contract/**/*.ts"
  ],
  "exclude": ["../platform_adapter/**/*.test.ts"]
}
