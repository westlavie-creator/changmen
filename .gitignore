apps/backend/data/esport/*.json
apps/backend/data/esport/*.b64
!apps/backend/data/esport/*.example.json
apps/backend/data/*.db
apps/backend/data/*.db-shm
apps/backend/data/*.db-wal
gamebet_backend/data/esport/*.json
gamebet_backend/data/esport/*.b64
!gamebet_backend/data/esport/*.example.json
gamebet_backend/data/*.db
gamebet_backend/data/*.db-shm
gamebet_backend/data/*.db-wal

# Codex / AI tool backup files
**/*.codex-backup-*
.env
.env.*
!.env.example
apps/matcher/.matcher-heartbeat.json
gamebet_matcher/.matcher-heartbeat.json

# Gamebet extension signing key (public key is in apps/chrome-extension/manifest.json)
apps/chrome-extension/key.pem
gamebet_chromeplug/key.pem

# Chrome extension reverse-engineering scratch (local analysis only)
apps/chrome-extension/scripts/_extracted/
gamebet_chromeplug/scripts/_extracted/

# Team name resolver runtime cache
packages/team-resolver/cache/*.json
!packages/team-resolver/cache/.gitkeep
team-resolver/cache/*.json
!team-resolver/cache/.gitkeep

# AI/session scratch (not product code)
memory/

# Large local captures / dumps
obdata.json
t.json
TJ01.JSON
a8-capture-report-*.json
arch-scan-report-*.json
*.7z
