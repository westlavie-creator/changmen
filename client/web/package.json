{
  "name": "@changmen/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck": "vue-tsc -b",
    "typecheck:node": "vue-tsc --noEmit -p tsconfig.node.json",
    "predev": "node scripts/bootstrap-dialogs.mjs && node scripts/gen-platform-icons-css.mjs && npm run typecheck:node",
    "dev": "vite",
    "prebuild": "node scripts/bootstrap-dialogs.mjs && node scripts/gen-platform-icons-css.mjs && node scripts/clean-dist-assets.mjs",
    "build": "node scripts/run-production-build.mjs",
    "build:analyze": "node scripts/run-production-build.mjs build --base=/ --mode analyze",
    "preview": "vite preview --base /",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:v4": "node scripts/test-v4-credit-plate.mjs",
    "test:ob-getmatchs": "node scripts/test-ob-getmatchs-shape.mjs",
    "test:ob-provider": "node scripts/test-ob-provider-contract.mjs",
    "test:ob-live": "node scripts/test-ob-live-smoke.mjs",
    "test:ob": "npm run test:ob-getmatchs && npm run test:ob-provider",
    "test:ob:all": "npm run test:ob && npm run test:ob-live",
    "analyze:deps": "node scripts/analyze-module-deps.mjs",
    "analyze:deps:check": "node scripts/analyze-module-deps.mjs --check"
  },
  "dependencies": {
    "@changmen/api-contract": "*",
    "@changmen/arb-core": "*",
    "@changmen/client-core": "*",
    "@changmen/shared": "*",
    "@noble/curves": "^1.4.2",
    "@polymarket/builder-relayer-client": "^0.0.10",
    "@polymarket/builder-signing-sdk": "^0.0.8",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@predictdotfun/sdk": "^1.3.6",
    "@vueuse/core": "^13.2.0",
    "axios": "^1.8.4",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.0",
    "ethers": "^6.17.0",
    "goeasy": "^2.14.9",
    "mqtt": "^5.14.1",
    "pinia": "^3.0.2",
    "socket.io-client": "^4.8.1",
    "socketcluster-client": "^19.2.0",
    "tronweb": "^6.3.0",
    "viem": "^2.53.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@changmen/match-engine": "*",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "~5.8.3",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.8"
  }
}
