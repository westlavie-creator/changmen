{
  "name": "@changmen/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/extract-a8-css.mjs && node scripts/sync-copy-preview-styles.mjs && node scripts/extract-a8-to-modules.mjs && node scripts/verify-copy-module-stack.mjs",
    "dev": "vite",
    "prebuild": "node scripts/extract-a8-css.mjs && node scripts/sync-copy-preview-styles.mjs && node scripts/extract-a8-to-modules.mjs && node scripts/verify-copy-module-stack.mjs && node scripts/clean-dist-assets.mjs",
    "build": "vue-tsc -b && vite build --base=/",
    "build:analyze": "vue-tsc -b && vite build --base=/ --mode analyze",
    "preview": "vite preview --base /",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:v4": "node scripts/test-v4-credit-plate.mjs",
    "test:ob-getmatchs": "node scripts/test-ob-getmatchs-shape.mjs",
    "test:ob-provider": "node scripts/test-ob-provider-contract.mjs",
    "test:ob-live": "node scripts/test-ob-live-smoke.mjs",
    "test:ob": "npm run test:ob-getmatchs && npm run test:ob-provider",
    "test:ob:all": "npm run test:ob && npm run test:ob-live",
    "audit:a8": "node scripts/audit-a8-parity.mjs",
    "verify:copy-modules": "node scripts/verify-copy-module-stack.mjs"
  },
  "dependencies": {
    "@changmen/api-contract": "*",
    "@changmen/shared": "*",
    "@vueuse/core": "^13.2.0",
    "axios": "^1.8.4",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.0",
    "goeasy": "^2.14.9",
    "mqtt": "^5.14.1",
    "pinia": "^3.0.2",
    "socket.io-client": "^4.8.1",
    "socketcluster-client": "^19.2.0",
    "tronweb": "^6.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@changmen/match-engine": "*",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "~5.8.3",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.8"
  }
}
