{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@changmen/shared/*": ["../../packages/shared/*"],
      "@platform/*": ["../platform-adapter/*"],
      "mqtt": ["../../node_modules/mqtt"],
      "socket.io-client": ["../../node_modules/socket.io-client"],
      "socketcluster-client": ["../../node_modules/socketcluster-client"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "../platform-adapter/**/index.ts",
    "../platform-adapter/**/frontend/**/*.ts",
    "../platform-adapter/ray/shared/**/*.ts",
    "../platform-adapter/ob/shared/**/*.ts",
    "../../packages/shared/catalog/market_catalog.browser.ts",
    "../../packages/shared/catalog/game_catalog.browser.ts",
    "../platform-adapter/shared/**/*.ts",
    "../platform-adapter/registry/**/*.ts",
    "../platform-adapter/contract/**/*.ts"
  ],
  "exclude": ["../platform-adapter/**/*.test.ts"]
}
