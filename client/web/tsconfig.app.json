{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@changmen/arb-core": ["../../packages/arb-core/src/index.ts"],
      "@changmen/arb-core/*": ["../../packages/arb-core/src/*"],
      "@changmen/client-core/*": ["../../packages/client-core/src/*"],
      "@changmen/shared/*": ["../../packages/shared/*"],
      "@changmen/venue-adapter": ["../../client/venue-adapter/registry/index.ts"],
      "@changmen/venue-adapter/*": ["../../client/venue-adapter/*"],
      "mqtt": ["../../node_modules/mqtt"],
      "socket.io-client": ["../../node_modules/socket.io-client"],
      "socketcluster-client": ["../../node_modules/socketcluster-client"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "../../packages/shared/catalog/market_catalog.browser.ts",
    "../../packages/shared/catalog/game_catalog.browser.ts"
  ],
  "exclude": [
    "../../client/venue-adapter/**/*.test.ts",
    "../../client/venue-adapter/**/scripts/**"
  ]
}
