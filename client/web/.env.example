# 开发默认走 Vite proxy（相对路径 /esport → VITE_API_PROXY 或本机 backend）
# VITE_API_PROXY=http://127.0.0.1:3560

# Vite 开发端口（默认 Windows 5274 / 其它 5174；Hyper-V 占用 5123-5222 时勿用 5174）
# VITE_DEV_PORT=5274

# 分离部署：前端静态与 API 不同源时设置 API 根（无尾部斜杠）
# VITE_API_BASE=https://api.example.com

# 本地 dev 时，http-relay / ws-forward 指向的 HK 服务端（无尾斜杠）
# VITE_HK_RELAY_ORIGIN=https://你的香港域名或IP

# Predict.fun 主网（测试网：VITE_PREDICT_FUN_API_BASE=https://api-testnet.predict.fun，可省略 Key）
# VITE_PREDICT_FUN_API_BASE=https://api.predict.fun
# VITE_PREDICT_FUN_API_KEY=

# 模式 A 运营主号（全站下注共用；用户 token 可仅 { "mode": "house" }）
# Predict Account（推荐）：从 https://predict.fun/account/settings 导出
# VITE_PREDICT_FUN_PRIVY_PRIVATE_KEY=
# VITE_PREDICT_FUN_PREDICT_ACCOUNT=
# 纯 EOA 备选：
# VITE_PREDICT_FUN_MASTER_PRIVATE_KEY=

# 其它已有变量见 docs/CREDIT_PLATE.md（VITE_V4_*、VITE_GAMEBET_EXTENSION_ID）

# DEV 本地联调：跳过扩展门控，Gate 直接出登录框（采集/下注仍要装扩展）
# 默认见 .env.development；覆盖：VITE_SKIP_EXTENSION_GATE=0 恢复强制检测
# VITE_SKIP_EXTENSION_GATE=1
