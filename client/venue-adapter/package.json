{
  "name": "@changmen/venue-adapter",
  "private": true,
  "type": "commonjs",
  "description": "各平台浏览器适配器（collect/bet + registry + loader）",
  "scripts": {
    "sync:backend-bundle": "node scripts/sync-backend-bundle.mjs",
    "ob:lock-observe": "npx tsx ob/scripts/ob_lock_observe.ts",
    "list:web-imports": "node scripts/list-web-venue-imports.mjs",
    "sync:exports": "node scripts/sync-package-exports.mjs",
    "check:exports": "node scripts/sync-package-exports.mjs --check",
    "check:internal-imports": "node scripts/relativize-internal-imports.mjs --check",
    "check:web-imports": "node scripts/list-web-venue-imports.mjs --check"
  },
  "exports": {
    ".": "./registry/index.ts",
    "./adaptation": "./adaptation/index.ts",
    "./contract": "./contract/index.ts",
    "./dex": "./dex/index.ts",
    "./hg": "./hg/index.ts",
    "./loader/adapter_paths.js": "./loader/adapter_paths.mjs",
    "./loader/adapter_paths.mjs": "./loader/adapter_paths.mjs",
    "./ob": "./ob/index.ts",
    "./pb": "./pb/index.ts",
    "./polymarket": "./polymarket/index.ts",
    "./polymarket/orderSettlement": "./polymarket/orderSettlement.ts",
    "./polymarket/orders": "./polymarket/orders.ts",
    "./polymarket/settlementJob": "./polymarket/settlementJob.ts",
    "./predictfun": "./predictfun/index.ts",
    "./ray": "./ray/index.ts",
    "./registry": "./registry/index.ts",
    "./registry/adapters": "./registry/adapters.ts",
    "./shared": "./shared/index.ts",
    "./shared/rejectWait": "./shared/rejectWait.ts",
    "./stake": "./stake/index.ts"
  },
  "dependencies": {
    "@changmen/api-contract": "*",
    "@changmen/client-core": "*",
    "@changmen/db": "*",
    "@changmen/storage": "*",
    "@changmen/shared": "*",
    "@predictdotfun/sdk": "^1.3.6",
    "ethers": "^6.15.0"
  }
}
