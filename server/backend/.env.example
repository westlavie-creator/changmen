# canonical：server/backend/.env（matcher 与运维脚本默认读本文件）
# 复制：BAT\setup-dev-env.bat  或  copy .env.example .env

# ── 必填（本地联调 / 登录）────────────────────────────
AUTH_MODE=jwt
JWT_SECRET=change-me-at-least-16-chars
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d
GAMEBET_DB_SCRIPT=rds

# RDS（配一条即可；内网+外网可同时写，启动 auto 探测，内网优先）
# DATABASE_URL=postgresql://user:pass@host:5432/gamebet
# DATABASE_URL_PUBLIC=postgresql://user:pass@pgm-xxx.pg.rds.aliyuncs.com:5432/gamebet
# DATABASE_URL_INTERNAL=postgresql://user:pass@pgm-xxx.pg.rds.aliyuncs.com:5432/gamebet
# DATABASE_RDS_TARGET=auto
# DATABASE_SSL=1

# ── 可选 ─────────────────────────────────────────────
# PORT=3560
# MATCHER_INTERVAL_MS=30000
# MATCHER_PRUNE_INTERVAL_MS=3600000
# MATCHER_UI_PORT=4567
# MATCHER_SKIP_AUTH=1
# TELEGRAM_BOT_TOKEN=
# 服务端管理员 Telegram（core/admin_tools；与客户端用户各自填 telegramId 独立）
# TELEGRAM_ADMIN_CHAT_ID=
# TELEGRAM_ADMIN_NOTIFY=1
# TELEGRAM_ORDER_NOTIFY=1
# TELEGRAM_ORDER_NOTIFY_MAX_AGE_MIN=120

# 管理员：users.is_admin — node scripts/create-user.js --admin <用户> <密码>
