{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "core/esport-api",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@changmen/api-contract": ["../../packages/api-contract/src/index.ts"],
      "@changmen/api-contract/*": ["../../packages/api-contract/src/*", "../../packages/api-contract/*"]
    },
    "types": ["node"],
    "allowJs": false,
    "declaration": false,
    "outDir": "core/esport-api",
    "sourceMap": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "core/esport-api/router.ts",
    "core/esport-api/admin_routes.ts",
    "core/esport-api/account_client_routes.ts"
  ],
  "exclude": ["**/*.js", "node_modules"]
}
