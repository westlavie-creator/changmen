# Value-bet 引擎配置（不设则用默认值，或从 server/backend/.env 读 DATABASE_URL）

# 锐利盘平台（默认 PB / 平博 / Pinnacle）
# VB_SHARP_PLATFORM=PB

# 扫描间隔毫秒（默认 15000 = 15秒）
# VB_SCAN_INTERVAL_MS=15000

# 最小 edge 阈值（默认 0.03 = 3%）
# VB_MIN_EDGE=0.03

# 最大 edge 阈值（默认 0.30 = 30%，超过通常是数据错误）
# VB_MAX_EDGE=0.30

# 赔率范围（默认 1.40~5.00）
# VB_MIN_ODDS=1.40
# VB_MAX_ODDS=5.00

# Kelly 缩放系数（默认 0.25 = 四分之一 Kelly）
# VB_KELLY_MULTIPLIER=0.25

# 信号过期时间毫秒（默认 300000 = 5分钟）
# VB_MAX_SIGNAL_AGE_MS=300000

# 目标软盘平台（逗号分隔）
# VB_SOFT_PLATFORMS=OB,IM,RAY,TF,IA,SABA,IMT,HG

# 去vig方法：multiplicative（默认）或 additive
# VB_VIG_METHOD=multiplicative
