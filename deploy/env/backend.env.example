# canonical：server/backend/.env（matcher 与运维脚本默认读本文件）
# 复制：BAT\setup-dev-env.bat  或  copy .env.example .env

# ── 必填（本地联调 / 登录）────────────────────────────
AUTH_MODE=jwt
JWT_SECRET=change-me-at-least-16-chars
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d
CHANGMEN_DB_SCRIPT=rds

# RDS（配一条即可；内网+外网可同时写，启动 auto 探测，内网优先）
# DATABASE_URL=postgresql://user:pass@host:5432/gamebet
# DATABASE_URL_PUBLIC=postgresql://user:pass@pgm-xxxho.pg.rds.aliyuncs.com:5432/gamebet
# DATABASE_URL_INTERNAL=postgresql://user:pass@pgm-xxx.pg.rds.aliyuncs.com:5432/gamebet
# DATABASE_RDS_TARGET=auto
# VPS 用 auto/internal；本机开发用 auto/public（勿在 VPS 写 public）
# DATABASE_SSL=1
# DATABASE_POOL_MAX=12
# DATABASE_POOL_CONNECT_TIMEOUT_MS=10000
# DATABASE_STATEMENT_TIMEOUT_MS=30000
# DATABASE_QUERY_TIMEOUT_MS=35000
# DATABASE_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000
# DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# DATABASE_POOL_MAX_LIFETIME_SEC=600
# DATABASE_APPLICATION_NAME=changmen-esport
# WS_FORWARD_PLATFORMS=IA,OB,RAY,PREDICTFUN-MARKET
# 说明：PM-MARKET 由 changmen-pm-market-hub（:3457）承担，勿列入上表
# PM_MARKET_HUB_PORT=3457

# ── 可选 ─────────────────────────────────────────────
# PORT=3560
# matchMerge 内嵌在 changmen-esport（npm run web 启动时自动跑 30s 循环）
# MATCHER_INTERVAL_MS=30000
# MATCHER_CLIENT_MATCH_ARCHIVE_INTERVAL_MS=3600000
# MATCHER_PRUNE_INTERVAL_MS=3600000  # 旧名，仍兼容
# COLLECTOR_HOT_CACHE_TTL_MS=180000
# MATCHER_UI_PORT=4567
# MATCHER_SKIP_AUTH=1
# 配对 / 真相表 / 发布策略等业务行为见 changmen/server/matcher/lib/config.js（勿用 env 开关）
# HTTP_RELAY_REQUIRE_TOKEN=1
# HTTP_RELAY_ALLOWED_HOSTS=gamma-api.polymarket.com,clob.polymarket.com,api.predict.fun,api-testnet.predict.fun
# HTTP_RELAY_ALLOWED_PATH_PREFIXES=/
# HTTP_RELAY_ALLOW_PRIVATE=0
# 可选：probe-hk-relay / 部署探针 JWT（HTTP_RELAY_REQUIRE_TOKEN=1 时在 VPS .env 与 GitHub secret PROBE_TOKEN 各设一份）
# PROBE_TOKEN=
# Predict.fun 主网 WS 中继（ws-forward/PREDICTFUN-MARKET 握手用；测试网可省略）
# PREDICT_FUN_API_KEY=
# 服务端管理员 Telegram（core/admin_tools；与客户端用户各自填 telegramId 独立）
# TELEGRAM_ADMIN_CHAT_ID=
# TELEGRAM_ADMIN_NOTIFY=1
# TELEGRAM_ORDER_NOTIFY=1
# TELEGRAM_ORDER_NOTIFY_MAX_AGE_MIN=120

# ── Polymarket Relayer（Plan A：密钥放服务端，客户端私钥签名）──
# changmen 多用户：用 Builder API Keys 三组（Settings > Builder > API Keys，DEV_CONFIG 同组）
# Builder 代任意用户钱包付 gas；每笔 Relayer 请求服务端算 HMAC。
# POLY_BUILDER_API_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=
# POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
#
# 单地址自用：Relayer API Key（2 项）。RELAYER_API_KEY_ADDRESS 必须 = 账号私钥对应地址。
# RELAYER_API_KEY=
# RELAYER_API_KEY_ADDRESS=0x...
# POLYMARKET_RELAYER_AUTH=relayer_api_key   # 强制用 Relayer Key（与 POLY_BUILDER_* 二选一）

# 管理员：users.is_admin — node scripts/create-user.js --admin <用户> <密码>
