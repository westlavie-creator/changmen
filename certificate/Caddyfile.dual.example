# changmen — HTTP 仅装证引导 + HTTPS mTLS
# :80 只服务 /setup（无客户端证）；其余 308 → https
# :443 强制 mTLS
# 证书：/etc/caddy/certs/{ca.crt,server.crt,server.key}
#
# 登录门 B：证书 + 插件。Caddy 须向 Node 注入客户端证头：
#   X-Changmen-Client-Cert / X-Changmen-Client-Subject
# 前端探测 GET /api/client-cert-status

{
	auto_https off
	servers {
		# IP + mTLS：放宽 SNI/Host 严格校验，避免浏览器/curl 421
		strict_sni_host insecure_off
	}
}

# mTLS 入口：注入证头供 /api/client-cert-status
(changmen_proxy_mtls) {
	reverse_proxy 127.0.0.1:3456 {
		header_up X-Changmen-Client-Cert 1
		header_up X-Changmen-Client-Subject {http.request.tls.client.subject}
	}
}

:80 {
	encode gzip

	# 证书安装引导（无需客户端证；先下载 ca.crt）
	handle /setup/ca.crt {
		root * /etc/caddy/certs
		rewrite * /ca.crt
		header Content-Type "application/x-x509-ca-cert"
		header Content-Disposition "attachment; filename=\"ca.crt\""
		file_server
	}
	handle /setup {
		redir * /setup/ permanent
	}
	handle_path /setup/* {
		root * /root/changmen/certificate-public
		file_server
	}

	# 其余全部跳到 HTTPS（正式站只走 :443 mTLS）
	handle {
		redir https://{host}{uri} permanent
	}
}

:443 {
	tls /etc/caddy/certs/server.crt /etc/caddy/certs/server.key {
		client_auth {
			mode require_and_verify
			trust_pool file /etc/caddy/certs/ca.crt
		}
	}

	encode gzip

	root * /root/changmen/client/web/dist

	handle /health {
		import changmen_proxy_mtls
	}
	# 须在 /esport/* 之前：PM-MARKET → 独立 hub :3457
	handle /esport/ws-forward/PM-MARKET* {
		reverse_proxy 127.0.0.1:3457
	}
	handle /esport/* {
		import changmen_proxy_mtls
	}
	handle /common/* {
		import changmen_proxy_mtls
	}
	handle /api/* {
		import changmen_proxy_mtls
	}
	handle /esport2/* {
		import changmen_proxy_mtls
	}
	@matcher_https path /matcher /matcher/*
	handle @matcher_https {
		import changmen_proxy_mtls
	}
	handle /v4.0/* {
		import changmen_proxy_mtls
	}

	@spa_html_https path / /index.html
	header @spa_html_https Cache-Control "no-cache, no-store, must-revalidate"

	@hashed_assets_https path /assets/*
	header @hashed_assets_https Cache-Control "public, max-age=31536000, immutable"

	handle {
		try_files {path} /index.html
		file_server
	}
}
